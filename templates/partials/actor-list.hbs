<colgroup>
    <col class="actor-cell-img" />
    <col class="actor-cell-name" />
    <col /> {{!-- This combined with the colspan="2" below lets us fake a min-width on the name column --}}
    {{#each headerData}}
    <col class="{{class}}" />
    {{/each}}
</colgroup>
<tr class="actor-header">
    <th></th>
    <th colspan="2" data-sort-id="name" style="text-align: start;">{{{localize "ACTOR_BROWSER.Name"}}}</th>
    {{#each headerData}}
    <th {{{sort}}}>{{{localize label}}}</th>
    {{/each}}
</tr>
{{> actorBrowserListRowsPartial actors=actors}}